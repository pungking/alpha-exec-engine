CNBC_RAPIDAPI_SYMBOL_PARAM=symbol
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_MARKET_SNAPSHOT_FOLDER_ID=
GDRIVE_STAGE6_FOLDER=
GDRIVE_REPORT_FOLDER=

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_PRIMARY_CHAT_ID=-1003800785574
TELEGRAM_SIMULATION_CHAT_ID=1281749368

# Market Guard (P3-2)
MARKET_GUARD_ENABLED=true
MARKET_GUARD_MODE=observe
MARKET_GUARD_INTERVAL_MIN=5
MARKET_GUARD_FORCE_SEND_ONCE=false
GUARD_ALLOW_OUTSIDE_RTH=false
GUARD_USE_INDEX_DROP=true
GUARD_QUALITY_ESCALATE_ENABLED=true
GUARD_FORCE_LEVEL=auto
GUARD_DEESCALATE_HOLD_MIN=20
GUARD_ACTION_COOLDOWN_MIN=15
GUARD_ACTION_LEDGER_TTL_DAYS=30
GUARD_L1_VIX=24
GUARD_L2_VIX=27
GUARD_L3_VIX=30
GUARD_L2_INDEX_DROP_PCT=1.8
GUARD_L3_INDEX_DROP_PCT=3.0
GUARD_TIGHTEN_STOP_PCT_L2=4
GUARD_TIGHTEN_STOP_PCT_L3=2
GUARD_MARKET_ORDER_TIF=day
GUARD_STOP_ORDER_TIF=day
GUARD_EXECUTE_TIGHTEN_STOPS=false
GUARD_EXECUTE_REDUCE_POSITIONS=false
GUARD_EXECUTE_FLATTEN=false

