NOTION_SYNC_MAX_RETRIES=2
NOTION_KEY_ROTATION_LEDGER_SYNC_ENABLED=true
NOTION_KEY_ROTATION_LEDGER_SYNC_REQUIRED=false
# Optional workspace pointers (for Notion project/worklist linking)
NOTION_PROJECT=
NOTION_WORK_LIST=
