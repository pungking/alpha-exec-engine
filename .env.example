# Core flags
EXEC_ENABLED=false
READ_ONLY=true
POLICY_VERSION=stage6-exec-v1.0-rc1
TZ=America/New_York
DRY_NOTIONAL_PER_TRADE=1000
DRY_MAX_ORDERS=3
DRY_MAX_TOTAL_NOTIONAL=3000
DRY_MIN_CONVICTION=70
DRY_MIN_STOP_DISTANCE_PCT=2
DRY_MAX_STOP_DISTANCE_PCT=25
ENTRY_FEASIBILITY_ENFORCE=false
ENTRY_MAX_DISTANCE_PCT=15
# Entry price mode:
# - strict: use Stage6 entry as-is (default, most conservative)
# - adaptive: allow bounded chase based on entryDistancePct while preserving RR floor
ENTRY_PRICE_MODE=strict
ENTRY_PRICE_MAX_CHASE_PCT=2.5
ENTRY_PRICE_DISTANCE_TRIGGER_PCT=2
ENTRY_PRICE_DISTANCE_SCALE=0.4
ENTRY_PRICE_MIN_RR=1.8
# High-price sizing:
# - skip: keep behavior conservative when one share costs more than DRY_NOTIONAL_PER_TRADE
# - min_one_share: allow one-share bracket entries only when notional/risk caps pass
ENTRY_HIGH_PRICE_POLICY=skip
ENTRY_MIN_ONE_SHARE_MAX_NOTIONAL=300
ENTRY_MAX_RISK_DOLLARS_PER_TRADE=25
# Execution overlay v1 (observe-only): enriches per-symbol audit with current market context.
EXECUTION_OVERLAY_ENABLED=true
# v1 supports observe only; non-observe values are ignored for safety.
EXECUTION_OVERLAY_MODE=observe
EXECUTION_OVERLAY_DATA_FEED=iex
EXECUTION_OVERLAY_MIN_RR=1.8
EXECUTION_OVERLAY_MAX_ADAPTIVE_DISTANCE_PCT=3
EXECUTION_OVERLAY_MAX_PULLBACK_DISTANCE_PCT=6
EXECUTION_OVERLAY_TARGET_BUFFER_PCT=1
EXECUTION_OVERLAY_DAILY_LOOKBACK_DAYS=260
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
STAGE6_EXECUTION_BUCKET_ENFORCE=true
# Actionable verdict policy (default: BUY/STRONG_BUY only)
# true -> include SPECULATIVE_BUY in actionable candidates
ACTIONABLE_INCLUDE_SPECULATIVE_BUY=false
# Position lifecycle scaffold (Phase A). Default keeps current behavior (ENTRY_NEW/HOLD_WAIT intent preview only).
POSITION_LIFECYCLE_ENABLED=false
POSITION_LIFECYCLE_PREVIEW_ONLY=true
POSITION_LIFECYCLE_ACTION_TYPES=ENTRY_NEW,HOLD_WAIT
POSITION_LIFECYCLE_SCALE_UP_MIN_CONVICTION=82
POSITION_LIFECYCLE_SCALE_DOWN_PCT=0.35
POSITION_LIFECYCLE_EXIT_PARTIAL_PCT=0.5
# Manual validation helper: emits deterministic lifecycle guard logs only.
LIFECYCLE_SELFTEST=false
# Approval queue gate (Phase 1-B): enforce only in live execution by default.
APPROVAL_REQUIRED=false
APPROVAL_ENFORCE_IN_PREVIEW=false
APPROVAL_QUEUE_FILE_NAME=APPROVAL_QUEUE.json
APPROVAL_REQUEST_TTL_MINUTES=180
# Simulation-for-live recommended profile (keep preview-only before live promotion):
# POSITION_LIFECYCLE_ENABLED=true
# POSITION_LIFECYCLE_PREVIEW_ONLY=true
# POSITION_LIFECYCLE_ACTION_TYPES=ENTRY_NEW,HOLD_WAIT,SCALE_UP,SCALE_DOWN,EXIT_PARTIAL,EXIT_FULL
# POSITION_LIFECYCLE_SCALE_DOWN_PCT=0.35
# POSITION_LIFECYCLE_EXIT_PARTIAL_PCT=0.5
# MCP Shadow Data Bus (Phase-1; read-only cross-validation lane)
SHADOW_DATA_BUS_ENABLED=false
SHADOW_SOURCE_ALPACA_ENABLED=true
SHADOW_SOURCE_ALPHA_VANTAGE_ENABLED=true
SHADOW_SOURCE_SEC_EDGAR_ENABLED=true
SHADOW_SOURCE_PERPLEXITY_ENABLED=true
SHADOW_SOURCE_SUPABASE_ENABLED=false
# HF sentiment soft gate (default OFF): adjusts conviction floor per-symbol, never hard-overrides core risk gates.
HF_SENTIMENT_SOFT_GATE_ENABLED=false
HF_SENTIMENT_SCORE_FLOOR=0.55
HF_SENTIMENT_MIN_ARTICLE_COUNT=2
HF_SENTIMENT_MAX_NEWS_AGE_HOURS=24
HF_EARNINGS_WINDOW_ENABLED=true
HF_EARNINGS_WINDOW_BLOCK_DAYS=1
HF_EARNINGS_WINDOW_REDUCE_DAYS=3
HF_EARNINGS_WINDOW_REDUCE_FACTOR=0.3
HF_SENTIMENT_POSITIVE_RELIEF_MAX=1.0
HF_SENTIMENT_NEGATIVE_TIGHTEN_MAX=2.0
# Manual payload drill helper (workflow_dispatch + preview-only safe lane).
HF_PAYLOAD_PROBE_MODE=off
# Optional soft size reduction on HF negative tighten (default OFF).
HF_NEGATIVE_SIZE_REDUCTION_ENABLED=false
HF_NEGATIVE_SIZE_REDUCTION_PCT=0.15
# Optional A/B shadow comparison (HF on/off) for observability only.
HF_SHADOW_ENABLED=false
# HF anomaly alert (log-only, warning telemetry).
HF_ALERT_ENABLED=true
HF_ALERT_SHADOW_PAYLOAD_DELTA_ABS=2
HF_ALERT_SHADOW_NOTIONAL_DELTA_ABS=1000
HF_ALERT_SHADOW_SKIPPED_DELTA_ABS=2
HF_DRIFT_ALERT_ENABLED=true
HF_DRIFT_ALERT_WINDOW_RUNS=8
HF_DRIFT_ALERT_MIN_HISTORY=4
HF_DRIFT_ALERT_MIN_CANDIDATES=3
HF_DRIFT_ALERT_NEGATIVE_RATIO_SPIKE=0.75
HF_DRIFT_ALERT_NEGATIVE_RATIO_DELTA=0.35
HF_DRIFT_ALERT_APPLIED_RATIO_DROP=0.25
HF_DRIFT_ALERT_APPLIED_RATIO_FLOOR=0.15
# Ignore no-payload runs when evaluating drift baseline/current sample (recommended ON).
HF_DRIFT_ALERT_REQUIRE_PAYLOAD=true
# HF freeze/unfreeze assistant (suggestion-only).
HF_TUNING_FREEZE_ENABLED=false
HF_TUNING_FREEZE_STABLE_RUNS=3
HF_TUNING_UNFREEZE_ALERT_STREAK=2
HF_TUNING_FREEZE_REQUIRE_PROGRESS=20
HF_TUNING_FREEZE_MAX_SHADOW_ALERT_RATE=0.10
# Live promotion checklist policy (suggestion-only gate configuration).
HF_LIVE_PROMOTION_REQUIRE_PERF_GATE_GO=true
HF_LIVE_PROMOTION_REQUIRE_FREEZE_FROZEN=true
HF_LIVE_PROMOTION_REQUIRE_SHADOW_STABLE=true
HF_LIVE_PROMOTION_REQUIRE_PAYLOAD_PATH_VERIFIED=true
# Sticky carry window for payload-path verification (hours, default 7d).
HF_LIVE_PROMOTION_PAYLOAD_PATH_STICKY_HOURS=168
VALIDATION_PACK_AUTO_TRIGGER_ENABLED=false
ORDER_IDEMPOTENCY_ENABLED=true
ORDER_IDEMPOTENCY_ENFORCE_DRY_RUN=false
ORDER_IDEMPOTENCY_TTL_DAYS=30
ORDER_IDEMPOTENCY_ENTRY_RESET_DAILY=true
PREFLIGHT_ENABLED=true
DAILY_MAX_NOTIONAL=5000
ALLOW_ENTRY_OUTSIDE_RTH=false
# If false, preflight blocking is recorded and payload is skipped but run exits 0.
PREFLIGHT_BLOCKING_HARD_FAIL=true
# Comma-separated preflight codes that should stay green even when blocking.
PREFLIGHT_SOFT_CODES=PREFLIGHT_MARKET_CLOSED
ORDER_LIFECYCLE_ENABLED=true
ORDER_LEDGER_TTL_DAYS=90
# Live order submission switch (default OFF): sends Alpaca /v2/orders only when preflight pass + payload exists.
LIVE_ORDER_SUBMIT_ENABLED=false
# Additional safety guard: require current perf gate status GO before live submit.
LIVE_ORDER_SUBMIT_REQUIRE_PERF_GATE_GO=true
# Additional safety guard: require HF Live Promotion status PASS before live submit.
LIVE_ORDER_SUBMIT_REQUIRE_HF_LIVE_PROMOTION_PASS=true
# Open-entry guard (default ON): blocks new entry submit when same symbol already has open buy entry.
ENTRY_OPEN_ORDER_GUARD_ENABLED=true
# Optional stale cleanup: cancel stale open entry before refreshed submit.
ENTRY_OPEN_ORDER_STALE_CANCEL_ENABLED=false
# Stale threshold (minutes) for open-entry cancellation when stale cleanup is enabled.
ENTRY_OPEN_ORDER_STALE_MINUTES=180
# Minimum absolute repricing delta (bps) required before stale cancel+replace.
ENTRY_OPEN_ORDER_REPLACE_MIN_DELTA_BPS=10
# Maximum upward chase (bps) allowed when replacing stale buy entry.
ENTRY_OPEN_ORDER_REPLACE_MAX_CHASE_BPS=120
# Cooldown (minutes) between stale cancel+replace actions per symbol.
ENTRY_OPEN_ORDER_REPLACE_COOLDOWN_MINUTES=10
# Maximum stale cancel+replace actions allowed per symbol per UTC day.
ENTRY_OPEN_ORDER_REPLACE_MAX_PER_SYMBOL_PER_DAY=3
FORCE_SEND_ONCE=false
TELEGRAM_SEND_ENABLED=true
TELEGRAM_HEARTBEAT_ON_DEDUPE=false
TELEGRAM_MAX_MESSAGE_LENGTH=3900
# Dry-run schedule watchdog (fallback trigger when scheduled run is stale/missed)
SIDECAR_WATCHDOG_ENABLED=true
SIDECAR_WATCHDOG_STALE_MINUTES=30
SIDECAR_WATCHDOG_LOOKBACK_MINUTES=180
SIDECAR_WATCHDOG_TARGET_WORKFLOW=dry-run.yml
SIDECAR_WATCHDOG_BRANCH=main
REGIME_AUTO_ENABLED=true
REGIME_FORCE_PROFILE=auto
REGIME_VIX_SOURCE_PRIORITY=realtime_first
REGIME_SNAPSHOT_MAX_AGE_MIN=10
REGIME_QUALITY_GUARD_ENABLED=true
REGIME_QUALITY_MIN_SCORE=60
REGIME_HYSTERESIS_ENABLED=true
REGIME_MIN_HOLD_MIN=30
REGIME_VIX_MISMATCH_PCT=8
GUARD_CONTROL_ENFORCE=false
GUARD_CONTROL_MAX_AGE_MIN=180
VIX_RISK_ON_THRESHOLD=22
VIX_RISK_OFF_THRESHOLD=25
GUARD_QUALITY_MIN_SCORE=60

# Profile split (optional). If empty, falls back to DRY_* values above.
DRY_DEFAULT_NOTIONAL_PER_TRADE=
DRY_DEFAULT_MAX_ORDERS=
DRY_DEFAULT_MAX_TOTAL_NOTIONAL=
DRY_DEFAULT_MIN_CONVICTION=
DRY_DEFAULT_MIN_CONVICTION_FLOOR=
DRY_DEFAULT_MIN_CONVICTION_CEILING=
DRY_DEFAULT_MIN_STOP_DISTANCE_PCT=
DRY_DEFAULT_MAX_STOP_DISTANCE_PCT=

DRY_RISK_OFF_NOTIONAL_PER_TRADE=
DRY_RISK_OFF_MAX_ORDERS=
DRY_RISK_OFF_MAX_TOTAL_NOTIONAL=
DRY_RISK_OFF_MIN_CONVICTION=
DRY_RISK_OFF_MIN_CONVICTION_FLOOR=
DRY_RISK_OFF_MIN_CONVICTION_CEILING=
DRY_RISK_OFF_MIN_STOP_DISTANCE_PCT=
DRY_RISK_OFF_MAX_STOP_DISTANCE_PCT=

# Alpaca (Paper)
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPHA_VANTAGE_API_KEY=
PERPLEXITY_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive
# Optional (legacy). Keep empty when using OAuth refresh token flow.
GDRIVE_API_KEY=
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
FINNHUB_API_KEY=
CNBC_RAPIDAPI_ENABLED=false
CNBC_RAPIDAPI_KEY=
CNBC_RAPIDAPI_HOST=cnbc.p.rapidapi.com
CNBC_RAPIDAPI_ENDPOINT=/market/get-quote
CNBC_RAPIDAPI_SYMBOL_PARAM=symbol
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_MARKET_SNAPSHOT_FOLDER_ID=
GDRIVE_STAGE6_FOLDER=
GDRIVE_REPORT_FOLDER=

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_PRIMARY_CHAT_ID=-1003800785574
TELEGRAM_SIMULATION_CHAT_ID=1281749368
TELEGRAM_ALERT_CHAT_ID=8646368794

# Market Guard (P3-2)
MARKET_GUARD_ENABLED=true
MARKET_GUARD_MODE=observe
MARKET_GUARD_INTERVAL_MIN=5
MARKET_GUARD_FORCE_SEND_ONCE=false
GUARD_ALLOW_OUTSIDE_RTH=false
GUARD_USE_INDEX_DROP=true
GUARD_QUALITY_ESCALATE_ENABLED=true
GUARD_FORCE_LEVEL=auto
GUARD_DEESCALATE_HOLD_MIN=20
GUARD_ACTION_COOLDOWN_MIN=15
GUARD_ACTION_LEDGER_TTL_DAYS=30
GUARD_L1_VIX=24
GUARD_L2_VIX=27
GUARD_L3_VIX=30
GUARD_L2_INDEX_DROP_PCT=1.8
GUARD_L3_INDEX_DROP_PCT=3.0
GUARD_TIGHTEN_STOP_PCT_L2=4
GUARD_TIGHTEN_STOP_PCT_L3=2
GUARD_MARKET_ORDER_TIF=day
GUARD_STOP_ORDER_TIF=day
GUARD_EXECUTE_TIGHTEN_STOPS=false
GUARD_EXECUTE_REDUCE_POSITIONS=false
GUARD_EXECUTE_FLATTEN=false

# Optional Notion sync (workflow summary upsert)
NOTION_TOKEN=
NOTION_DB_DAILY_SNAPSHOT=
NOTION_DB_GUARD_ACTION_LOG=
NOTION_DB_HF_TUNING_TRACKER=
NOTION_DB_PERFORMANCE_DASHBOARD=
NOTION_DB_AUTOMATION_INCIDENT_LOG=
NOTION_DB_KEY_ROTATION_LEDGER=
NOTION_SIDECAR_SYNC_ENABLED=true
NOTION_SIDECAR_SYNC_REQUIRED=false
NOTION_MARKET_GUARD_SYNC_ENABLED=true
NOTION_MARKET_GUARD_SYNC_REQUIRED=false
NOTION_GUARD_ACTION_LOG_SYNC_ENABLED=true
NOTION_GUARD_ACTION_LOG_SYNC_REQUIRED=false
NOTION_HF_TUNING_TRACKER_SYNC_ENABLED=true
NOTION_HF_TUNING_TRACKER_SYNC_REQUIRED=false
NOTION_PERFORMANCE_DASHBOARD_SYNC_ENABLED=true
NOTION_PERFORMANCE_DASHBOARD_SYNC_REQUIRED=false
NOTION_PERF_PERCENT_BACKFILL_DRY_RUN=true
NOTION_PERF_PERCENT_BACKFILL_THRESHOLD=1
NOTION_PERF_PERCENT_BACKFILL_ROUND_ALL=false
NOTION_PERF_PERCENT_BACKFILL_DISPLAY_DIGITS=2
NOTION_PERF_PERCENT_BACKFILL_PAGE_SIZE=100
NOTION_PERF_PERCENT_BACKFILL_MAX_PAGES=50
NOTION_AUTOMATION_INCIDENT_LOG_SYNC_ENABLED=true
NOTION_AUTOMATION_INCIDENT_LOG_SYNC_REQUIRED=false
