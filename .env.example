# Core flags
EXEC_ENABLED=false
READ_ONLY=true
POLICY_VERSION=stage6-exec-v1.0-rc1
TZ=America/New_York
DRY_NOTIONAL_PER_TRADE=1000
DRY_MAX_ORDERS=3
DRY_MAX_TOTAL_NOTIONAL=3000
DRY_MIN_CONVICTION=70
DRY_MIN_STOP_DISTANCE_PCT=2
DRY_MAX_STOP_DISTANCE_PCT=25
ENTRY_FEASIBILITY_ENFORCE=false
ENTRY_MAX_DISTANCE_PCT=15
STAGE6_EXECUTION_BUCKET_ENFORCE=true
# Actionable verdict policy (default: BUY/STRONG_BUY only)
# true -> include SPECULATIVE_BUY in actionable candidates
ACTIONABLE_INCLUDE_SPECULATIVE_BUY=false
# Position lifecycle scaffold (Phase A). Default keeps current behavior (ENTRY_NEW/HOLD_WAIT intent preview only).
POSITION_LIFECYCLE_ENABLED=false
POSITION_LIFECYCLE_PREVIEW_ONLY=true
POSITION_LIFECYCLE_ACTION_TYPES=ENTRY_NEW,HOLD_WAIT
POSITION_LIFECYCLE_SCALE_UP_MIN_CONVICTION=82
# HF sentiment soft gate (default OFF): adjusts conviction floor per-symbol, never hard-overrides core risk gates.
HF_SENTIMENT_SOFT_GATE_ENABLED=false
HF_SENTIMENT_SCORE_FLOOR=0.55
HF_SENTIMENT_MIN_ARTICLE_COUNT=2
HF_SENTIMENT_MAX_NEWS_AGE_HOURS=24
HF_EARNINGS_WINDOW_ENABLED=true
HF_EARNINGS_WINDOW_BLOCK_DAYS=1
HF_EARNINGS_WINDOW_REDUCE_DAYS=3
HF_EARNINGS_WINDOW_REDUCE_FACTOR=0.3
HF_SENTIMENT_POSITIVE_RELIEF_MAX=1.0
HF_SENTIMENT_NEGATIVE_TIGHTEN_MAX=2.0
# Manual payload drill helper (workflow_dispatch + preview-only safe lane).
HF_PAYLOAD_PROBE_MODE=off
# Optional soft size reduction on HF negative tighten (default OFF).
HF_NEGATIVE_SIZE_REDUCTION_ENABLED=false
HF_NEGATIVE_SIZE_REDUCTION_PCT=0.15
# Optional A/B shadow comparison (HF on/off) for observability only.
HF_SHADOW_ENABLED=false
# HF anomaly alert (log-only, warning telemetry).
HF_ALERT_ENABLED=true
HF_ALERT_SHADOW_PAYLOAD_DELTA_ABS=2
HF_ALERT_SHADOW_NOTIONAL_DELTA_ABS=1000
HF_ALERT_SHADOW_SKIPPED_DELTA_ABS=2
HF_DRIFT_ALERT_ENABLED=true
HF_DRIFT_ALERT_WINDOW_RUNS=8
HF_DRIFT_ALERT_MIN_HISTORY=4
HF_DRIFT_ALERT_MIN_CANDIDATES=3
HF_DRIFT_ALERT_NEGATIVE_RATIO_SPIKE=0.75
HF_DRIFT_ALERT_NEGATIVE_RATIO_DELTA=0.35
HF_DRIFT_ALERT_APPLIED_RATIO_DROP=0.25
HF_DRIFT_ALERT_APPLIED_RATIO_FLOOR=0.15
# HF freeze/unfreeze assistant (suggestion-only).
HF_TUNING_FREEZE_ENABLED=false
HF_TUNING_FREEZE_STABLE_RUNS=3
HF_TUNING_UNFREEZE_ALERT_STREAK=2
HF_TUNING_FREEZE_REQUIRE_PROGRESS=20
HF_TUNING_FREEZE_MAX_SHADOW_ALERT_RATE=0.10
# Live promotion checklist policy (suggestion-only gate configuration).
HF_LIVE_PROMOTION_REQUIRE_PERF_GATE_GO=true
HF_LIVE_PROMOTION_REQUIRE_FREEZE_FROZEN=true
HF_LIVE_PROMOTION_REQUIRE_SHADOW_STABLE=true
HF_LIVE_PROMOTION_REQUIRE_PAYLOAD_PATH_VERIFIED=true
ORDER_IDEMPOTENCY_ENABLED=true
ORDER_IDEMPOTENCY_ENFORCE_DRY_RUN=false
ORDER_IDEMPOTENCY_TTL_DAYS=30
PREFLIGHT_ENABLED=true
DAILY_MAX_NOTIONAL=5000
ALLOW_ENTRY_OUTSIDE_RTH=false
# If false, preflight blocking is recorded and payload is skipped but run exits 0.
PREFLIGHT_BLOCKING_HARD_FAIL=true
ORDER_LIFECYCLE_ENABLED=true
ORDER_LEDGER_TTL_DAYS=90
FORCE_SEND_ONCE=false
TELEGRAM_HEARTBEAT_ON_DEDUPE=false
TELEGRAM_MAX_MESSAGE_LENGTH=3900
REGIME_AUTO_ENABLED=true
REGIME_FORCE_PROFILE=auto
REGIME_VIX_SOURCE_PRIORITY=realtime_first
REGIME_SNAPSHOT_MAX_AGE_MIN=10
REGIME_QUALITY_GUARD_ENABLED=true
REGIME_QUALITY_MIN_SCORE=60
REGIME_HYSTERESIS_ENABLED=true
REGIME_MIN_HOLD_MIN=30
REGIME_VIX_MISMATCH_PCT=8
GUARD_CONTROL_ENFORCE=false
GUARD_CONTROL_MAX_AGE_MIN=180
VIX_RISK_ON_THRESHOLD=22
VIX_RISK_OFF_THRESHOLD=25
GUARD_QUALITY_MIN_SCORE=60

# Profile split (optional). If empty, falls back to DRY_* values above.
DRY_DEFAULT_NOTIONAL_PER_TRADE=
DRY_DEFAULT_MAX_ORDERS=
DRY_DEFAULT_MAX_TOTAL_NOTIONAL=
DRY_DEFAULT_MIN_CONVICTION=
DRY_DEFAULT_MIN_CONVICTION_FLOOR=
DRY_DEFAULT_MIN_CONVICTION_CEILING=
DRY_DEFAULT_MIN_STOP_DISTANCE_PCT=
DRY_DEFAULT_MAX_STOP_DISTANCE_PCT=

DRY_RISK_OFF_NOTIONAL_PER_TRADE=
DRY_RISK_OFF_MAX_ORDERS=
DRY_RISK_OFF_MAX_TOTAL_NOTIONAL=
DRY_RISK_OFF_MIN_CONVICTION=
DRY_RISK_OFF_MIN_CONVICTION_FLOOR=
DRY_RISK_OFF_MIN_CONVICTION_CEILING=
DRY_RISK_OFF_MIN_STOP_DISTANCE_PCT=
DRY_RISK_OFF_MAX_STOP_DISTANCE_PCT=

