{
  "name": "alpha-exec-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "progress:overall": "node scripts/progress-summary.mjs",
    "progress:daily": "node scripts/progress-daily.mjs",
    "evidence:snippet": "node scripts/evidence-snippet.mjs",
    "dashboard:perf": "node scripts/build-performance-dashboard.mjs",
    "ops:health": "node scripts/build-ops-health-report.mjs",
    "ops:health:dry-run": "OPS_HEALTH_KIND=dry_run node scripts/build-ops-health-report.mjs",
    "ops:health:market-guard": "OPS_HEALTH_KIND=market_guard node scripts/build-ops-health-report.mjs",
    "ops:notion:audit": "node scripts/build-notion-ops-audit.mjs",
    "ops:daily:report": "node scripts/build-ops-daily-report.mjs",
    "ops:daily:notion:sync": "node scripts/sync-notion-ops-daily.mjs",
    "ops:approval:queue": "node scripts/manage-approval-queue.mjs",
    "backfill:notion:perf-pct:dry": "node scripts/backfill-notion-performance-percent.mjs",
    "backfill:notion:perf-pct": "NOTION_PERF_PERCENT_BACKFILL_DRY_RUN=false node scripts/backfill-notion-performance-percent.mjs",
    "start": "node dist/src/index.js",
    "guard": "node dist/src/market-guard.js",
    "check:json-parse-guard": "node scripts/check-json-parse-guard.mjs",
    "sync:notion:dry-run": "node scripts/sync-notion-summary.mjs",
    "sync:notion:market-guard": "NOTION_SYNC_KIND=market_guard node scripts/sync-notion-summary.mjs",
    "validation-pack:auto": "node scripts/maybe-trigger-validation-pack.mjs",
    "test:hf:dist": "node --test dist/src/hf-judgement-core.test.js",
    "test:hf": "npm run build && node --test dist/src/hf-judgement-core.test.js",
    "verify:hf": "npm run build && npm run check:json-parse-guard && npm run test:hf:dist && npm run replay:hf:fixture:dist",
    "replay:hf:dist": "node dist/src/replay-hf-judgement.js",
    "replay:hf:strict:dist": "node dist/src/replay-hf-judgement.js --strict",
    "replay:hf:fixture:dist": "node dist/src/replay-hf-judgement.js --preview testdata/replay/preview.fixture.json --stage6 testdata/replay/stage6.fixture.json --baseline testdata/replay/baseline.summary.json --out state/replay_fixture_summary.json --strict --expect-no-diff",
    "replay:hf": "npm run build && node dist/src/replay-hf-judgement.js",
    "replay:hf:strict": "npm run build && node dist/src/replay-hf-judgement.js --strict",
    "replay:hf:fixture": "npm run build && node dist/src/replay-hf-judgement.js --preview testdata/replay/preview.fixture.json --stage6 testdata/replay/stage6.fixture.json --baseline testdata/replay/baseline.summary.json --out state/replay_fixture_summary.json --strict --expect-no-diff"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.9.2"
  }
}
