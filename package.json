{
  "name": "alpha-exec-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "progress:overall": "node scripts/progress-summary.mjs",
    "progress:daily": "node scripts/progress-daily.mjs",
    "evidence:snippet": "node scripts/evidence-snippet.mjs",
    "dashboard:perf": "node scripts/build-performance-dashboard.mjs",
    "ops:broker-child-reconcile": "node scripts/build-broker-child-order-reconciliation.mjs",
    "ops:position-protection:audit": "node scripts/build-position-protection-root-cause-audit.mjs",
    "ops:position-lifecycle-guard-source": "node scripts/build-position-lifecycle-guard-source-plan.mjs",
    "ops:guard-metadata-refresh": "node scripts/build-guard-metadata-refresh-plan.mjs",
    "ops:guard-metadata:lineage": "node scripts/build-guard-metadata-lineage-audit.mjs",
    "ops:guarded-repair-plan": "node scripts/build-guarded-child-order-repair-plan.mjs",
    "ops:lane-status": "node scripts/build-ops-lane-status-report.mjs",
    "ops:health": "node scripts/build-ops-health-report.mjs",
    "ops:health:dry-run": "OPS_HEALTH_KIND=dry_run node scripts/build-ops-health-report.mjs",
    "ops:health:market-guard": "OPS_HEALTH_KIND=market_guard node scripts/build-ops-health-report.mjs",
    "ops:fillability": "node scripts/build-fillability-report.mjs",
    "ops:entry-reprice-policy": "node scripts/build-entry-reprice-policy-decision.mjs",
    "ops:stage6-fillability-mismatch": "node scripts/build-stage6-fillability-mismatch-audit.mjs",
    "ops:high-price:min-one-share-canary": "node scripts/build-high-price-min-one-share-canary-plan.mjs",
    "ops:high-price:min-one-share-contract": "node scripts/validate-high-price-min-one-share-contract.mjs",
    "ops:high-price:min-one-share-fixtures": "node scripts/validate-high-price-min-one-share-fixtures.mjs",
    "ops:exec:blockers": "node scripts/build-execution-blocker-audit.mjs",
    "ops:notion:audit": "node scripts/build-notion-ops-audit.mjs",
    "ops:daily:report": "node scripts/build-ops-daily-report.mjs",
    "ops:daily:notion:sync": "node scripts/sync-notion-ops-daily.mjs",
    "ops:approval:queue": "node scripts/manage-approval-queue.mjs",
    "backfill:notion:perf-pct:dry": "node scripts/backfill-notion-performance-percent.mjs",
    "backfill:notion:perf-pct": "NOTION_PERF_PERCENT_BACKFILL_DRY_RUN=false node scripts/backfill-notion-performance-percent.mjs",
    "start": "node dist/src/index.js",
    "guard": "node dist/src/market-guard.js",
    "check:json-parse-guard": "node scripts/check-json-parse-guard.mjs",
    "sync:notion:dry-run": "node scripts/sync-notion-summary.mjs",
    "sync:notion:market-guard": "NOTION_SYNC_KIND=market_guard node scripts/sync-notion-summary.mjs",
    "validation-pack:auto": "node scripts/maybe-trigger-validation-pack.mjs",
    "test:hf:dist": "node --test dist/src/hf-judgement-core.test.js",
    "test:hf": "npm run build && node --test dist/src/hf-judgement-core.test.js",
    "verify:hf": "npm run build && npm run check:json-parse-guard && npm run test:hf:dist && npm run replay:hf:fixture:dist",
    "replay:hf:dist": "node dist/src/replay-hf-judgement.js",
    "replay:hf:strict:dist": "node dist/src/replay-hf-judgement.js --strict",
    "replay:hf:fixture:dist": "node dist/src/replay-hf-judgement.js --preview testdata/replay/preview.fixture.json --stage6 testdata/replay/stage6.fixture.json --baseline testdata/replay/baseline.summary.json --out state/replay_fixture_summary.json --strict --expect-no-diff",
    "replay:hf": "npm run build && node dist/src/replay-hf-judgement.js",
    "replay:hf:strict": "npm run build && node dist/src/replay-hf-judgement.js --strict",
    "replay:hf:fixture": "npm run build && node dist/src/replay-hf-judgement.js --preview testdata/replay/preview.fixture.json --stage6 testdata/replay/stage6.fixture.json --baseline testdata/replay/baseline.summary.json --out state/replay_fixture_summary.json --strict --expect-no-diff",
    "ops:order-state": "node scripts/build-order-state-consistency-report.mjs",
    "ops:open-order-reprice-proposal": "node scripts/build-open-order-reprice-proposal.mjs",
    "ops:alpaca:payload-fixtures": "node scripts/validate-alpaca-order-payload-fixtures.mjs",
    "ops:alpaca:oco-response-fixtures": "node scripts/validate-alpaca-oco-response-fixtures.mjs",
    "ops:paper-oco-canary": "node scripts/build-paper-oco-canary-candidate.mjs",
    "ops:paper-oco-gate": "node scripts/build-paper-oco-canary-approval-gate.mjs",
    "ops:paper-oco-submit-gate": "node scripts/run-paper-oco-canary-submit.mjs",
    "ops:paper-oco-result": "node scripts/build-paper-oco-canary-result-report.mjs",
    "sync:notion:paper-oco-result": "node scripts/sync-paper-oco-canary-result.mjs",
    "ops:persistent-oco-plan": "node scripts/build-persistent-oco-repair-plan.mjs",
    "ops:persistent-oco-submit": "node scripts/run-persistent-oco-repair-submit.mjs",
    "ops:persistent-oco-open-verify": "node scripts/verify-persistent-oco-repair-open.mjs",
    "ops:persistent-oco-open-verify:multi": "node scripts/verify-persistent-oco-repair-open-multi.mjs",
    "ops:safety:symbol-agnostic": "node scripts/check-symbol-agnostic-runtime.mjs",
    "ops:guard-source-recovery": "node scripts/build-guard-source-recovery-plan.mjs",
    "ops:fill-state-reconcile": "node scripts/build-fill-state-reconciliation-audit.mjs",
    "ops:broker-fill-state-evidence": "node scripts/build-broker-fill-state-evidence.mjs",
    "ops:ledger-terminalization-proposal": "node scripts/build-ledger-terminalization-proposal.mjs",
    "ops:ledger-filled-migration-plan": "node scripts/build-ledger-filled-migration-plan.mjs",
    "ops:ledger-filled-migration-apply": "node scripts/apply-ledger-filled-migration.mjs",
    "ops:limited-multi-oco-plan": "node scripts/build-limited-multi-oco-repair-plan.mjs",
    "ops:position-ownership-guard-gap": "node scripts/build-position-ownership-guard-gap-audit.mjs",
    "ops:position-ownership-recovery-decision": "node scripts/build-position-ownership-recovery-decision.mjs",
    "ops:position-ownership-recovery-gate": "node scripts/build-position-ownership-recovery-approval-gate.mjs",
    "ops:position-ownership-state-migration-review": "node scripts/build-position-ownership-state-migration-review-plan.mjs",
    "ops:multi-oco-submit-gate": "node scripts/build-multi-oco-submit-safety-gate.mjs",
    "ops:no-actionable-event": "node scripts/build-no-actionable-event-escalation.mjs",
    "ops:test:ownership-gates": "node scripts/test-ownership-recovery-safety-gates.mjs",
    "ops:safety:telegram-routing": "node scripts/check-telegram-routing-policy.mjs",
    "ops:live-readiness": "node scripts/build-live-readiness-scorecard.mjs",
    "ops:test:dry-run-dispatch-safety": "node scripts/check-dry-run-dispatch-safety.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.9.2"
  }
}
